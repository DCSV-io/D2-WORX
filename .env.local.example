# D2-WORX Environment Variables
# Copy this file to .env.local and fill in your values.
# WARNING: Never commit .env.local to version control.
#
# THIS FILE IS THE SINGLE SOURCE OF TRUTH for all configuration.
# Code reads env vars with NO defaults — if a required var is missing, it crashes.
#
# Convention: SERVICE_LAYER__PROPERTY (double underscore = hierarchy separator).
# .NET AddEnvironmentVariables() auto-maps __ to : for IConfiguration binding.
# Node.js services parse the same env vars directly.

# ===========================================
# Aspire Parameters (credentials)
# ===========================================
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here
DBA_EMAIL=admin@example.com
DBA_PASSWORD=your_secure_password_here
MQ_USERNAME=rabbitmq
MQ_PASSWORD=your_secure_password_here
CACHE_PASSWORD=your_secure_password_here
S3_USERNAME=minio
S3_PASSWORD=your_secure_password_here
OTEL_USERNAME=admin
OTEL_PASSWORD=your_secure_password_here

# ===========================================
# Observability — Shared Config
# ===========================================
# Base path for observability config bind mounts (relative to AppHost project).
OBSERVABILITY_CONFIG_PATH=../../../../observability
OTEL_CLUSTER_NAME=d2-local-dev
OTEL_ENVIRONMENT=Development

# ===========================================
# MinIO — S3 Compatible Object Storage
# ===========================================
MINIO_NAME=d2-minio
MINIO_IMAGE=minio/minio
MINIO_TAG=RELEASE.2025-09-07T16-13-09Z
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_VOLUME=d2-minio-data
MINIO_TOKENS_VOLUME=d2-minio-tokens
MINIO_BUCKET_LOKI=loki-logs
MINIO_BUCKET_TEMPO=tempo-traces
MINIO_BUCKET_MIMIR_BLOCKS=mimir-blocks
MINIO_BUCKET_MIMIR_RULER=mimir-ruler
MINIO_BUCKET_UPLOADS=minio-uploads

# MinIO Client (init buckets)
MINIO_INIT_NAME=d2-minio-init
MINIO_MC_IMAGE=minio/mc
MINIO_MC_TAG=RELEASE.2025-08-13T08-35-41Z

# ===========================================
# Loki — Log Aggregation
# ===========================================
LOKI_NAME=d2-loki
LOKI_IMAGE=grafana/loki
LOKI_TAG=3.5.10
LOKI_HTTP_PORT=3100
LOKI_GRPC_PORT=9095
LOKI_VOLUME=d2-loki-data

# ===========================================
# Tempo — Distributed Tracing
# ===========================================
TEMPO_NAME=d2-tempo
TEMPO_IMAGE=grafana/tempo
TEMPO_TAG=2.10.1
TEMPO_HTTP_PORT=3200
TEMPO_GRPC_PORT=9096
TEMPO_VOLUME=d2-tempo-data

# ===========================================
# Mimir — Metrics
# ===========================================
MIMIR_NAME=d2-mimir
MIMIR_IMAGE=grafana/mimir
MIMIR_TAG=2.17.7
MIMIR_HTTP_PORT=9009
MIMIR_GRPC_PORT=9097
MIMIR_VOLUME=d2-mimir-data

# ===========================================
# cAdvisor — Container Resource Monitoring
# ===========================================
CADVISOR_NAME=d2-cadvisor
CADVISOR_IMAGE=gcr.io/cadvisor/cadvisor
CADVISOR_TAG=v0.52.1
CADVISOR_PORT=8081

# ===========================================
# Grafana Alloy — Unified OTel Agent
# ===========================================
ALLOY_NAME=d2-alloy
ALLOY_IMAGE=grafana/alloy
ALLOY_TAG=v1.13.2
ALLOY_HTTP_PORT=12345
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318
ALLOY_VOLUME=d2-alloy-data

# ===========================================
# Grafana — Visualization
# ===========================================
GRAFANA_NAME=d2-grafana
GRAFANA_IMAGE=grafana/grafana
GRAFANA_TAG=12.4.0
GRAFANA_PORT=3000
GRAFANA_VOLUME=d2-grafana-data
GRAFANA_COOKIE_SECURE=false
GRAFANA_COOKIE_SAMESITE=lax
GRAFANA_STRICT_TRANSPORT_SECURITY=false

# ===========================================
# PostgreSQL + pgAdmin + Exporter
# ===========================================
POSTGRES_NAME=d2-postgres
POSTGRES_TAG=18.3-trixie
POSTGRES_PORT=54320
POSTGRES_VOLUME=d2-postgres-data

PGADMIN_NAME=d2-pgadmin
PGADMIN_TAG=9.12
PGADMIN_PORT=5533

PG_EXPORTER_NAME=d2-pg-exporter
PG_EXPORTER_IMAGE=prometheuscommunity/postgres-exporter
PG_EXPORTER_TAG=v0.19.1
PG_EXPORTER_PORT=9187

# ===========================================
# Redis + RedisInsight + Exporter
# ===========================================
REDIS_NAME=d2-redis
REDIS_TAG=8.2.4-bookworm
REDIS_PORT=6379
REDIS_VOLUME=d2-redis-data

REDISINSIGHT_NAME=d2-redisinsight
REDISINSIGHT_TAG=2.70.1
REDISINSIGHT_PORT=5540
REDISINSIGHT_VOLUME=d2-redisinsight-data

REDIS_EXPORTER_NAME=d2-redis-exporter
REDIS_EXPORTER_IMAGE=oliver006/redis_exporter
REDIS_EXPORTER_TAG=v1.80.1
REDIS_EXPORTER_PORT=9121

# ===========================================
# RabbitMQ — Message Broker
# ===========================================
RABBITMQ_NAME=d2-rabbitmq
RABBITMQ_TAG=4.1.7-management
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_METRICS_PORT=15692
RABBITMQ_VOLUME=d2-rabbitmq-data

# ===========================================
# Dkron — Distributed Job Scheduler
# ===========================================
DKRON_NAME=d2-dkron
DKRON_IMAGE=dkron/dkron
DKRON_TAG=4.0.9
DKRON_DASHBOARD_PORT=8888
DKRON_VOLUME=d2-dkron-data

# ===========================================
# OTel Endpoints
# ===========================================
OTLP_HTTP_ENDPOINT=http://localhost:4318
LOKI_PUSH_ENDPOINT=http://localhost:3100

# ===========================================
# Database Names
# ===========================================
# When true, .NET services apply EF Core migrations on startup (local dev).
AUTO_MIGRATE=true

GEO_DB_NAME=d2-services-geo
AUTH_DB_NAME=d2-services-auth
COMMS_DB_NAME=d2-services-comms

# ===========================================
# Connection URLs
# ===========================================
# D2Env.Load() / loadEnv() set these from .env.local;
# they are never overwritten if Aspire has already set them (SetIfAbsent semantics).
# Port 54320 = external PG port from POSTGRES_PORT above.
REDIS_URL=redis://:your_cache_password@localhost:6379
RABBITMQ_URL=amqp://your_mq_user:your_mq_password@localhost:5672

# ===========================================
# gRPC Service Addresses
# ===========================================
# Bare host:port — consumers prepend http://
GEO_GRPC_ADDRESS=localhost:5138
AUTH_GRPC_ADDRESS=localhost:5101
COMMS_GRPC_ADDRESS=localhost:5200

# ===========================================
# Service Names (Aspire resource names)
# ===========================================
GEO_SERVICE_NAME=d2-geo
AUTH_SERVICE_NAME=d2-auth
COMMS_SERVICE_NAME=d2-comms
GATEWAY_SERVICE_NAME=d2-gateway
DKRON_MGR_SERVICE_NAME=d2-dkron-mgr
SVELTEKIT_SERVICE_NAME=d2-sveltekit

# ===========================================
# Geo Service
# ===========================================
# Endpoint for Alloy to scrape Prometheus metrics from Geo (.NET on host).
GEO_METRICS_ENDPOINT=host.docker.internal:5138

GEO_DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:54320/d2-services-geo

# IPInfo API token for WhoIs/geolocation lookups
# Get a free token at https://ipinfo.io/signup
GEO_INFRA__IPINFOACCESSTOKEN=your_ipinfo_token_here

# API key → context key mappings
# Format: GEO_APP__APIKEYMAPPINGS__<api-key>__<index>=<context-key>
GEO_APP__APIKEYMAPPINGS__your_auth_api_key_here__0=org_contact
GEO_APP__APIKEYMAPPINGS__your_auth_api_key_here__1=user
GEO_APP__APIKEYMAPPINGS__your_comms_api_key_here__0=org_contact
GEO_APP__APIKEYMAPPINGS__your_comms_api_key_here__1=user
GEO_APP__APIKEYMAPPINGS__your_sveltekit_geo_key_here__0=_sveltekit
GEO_APP__APIKEYMAPPINGS__your_gateway_api_key_here__0=_gateway
GEO_APP__JOBLOCKTTLSECONDS=300
GEO_APP__WHOISRETENTIONDAYS=180

# Geo Client — Auth Service
AUTH_GEO_CLIENT__APIKEY=your_api_key_here

# Geo Client — Comms Service
COMMS_GEO_CLIENT__APIKEY=your_api_key_here

# ===========================================
# Auth Service
# ===========================================
AUTH_DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:54320/d2-services-auth
AUTH_BASE_URL=http://localhost:5100
AUTH_CORS_ORIGIN=http://localhost:5173
AUTH_JWT_ISSUER=d2-worx
AUTH_JWT_AUDIENCE=d2-services
AUTH_HTTP_PORT=5100
AUTH_GRPC_PORT=5101
AUTH_API_KEYS__0=your_gateway_api_key_here

AUTH_APP__SIGNINEVENTRETENTIONDAYS=90
AUTH_APP__INVITATIONRETENTIONDAYS=7
AUTH_APP__JOBLOCKTTLMS=300000

# ===========================================
# Comms Service
# ===========================================
COMMS_DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:54320/d2-services-comms
COMMS_API_KEYS__0=your_auth_comms_api_key_here
COMMS_API_KEYS__1=your_gateway_api_key_here
COMMS_GRPC_PORT=5200

COMMS_APP__DELETEDMESSAGERETENTIONDAYS=90
COMMS_APP__DELIVERYHISTORYRETENTIONDAYS=365
COMMS_APP__JOBLOCKTTLMS=300000

# Resend — Email provider
# Sign up at https://resend.com/signup (100 emails/day free)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_ADDRESS=onboarding@resend.dev

# Twilio — SMS provider (optional, SMS is a fallback channel)
# Sign up at https://www.twilio.com/try-twilio ($15 credit)
TWILIO_ACCOUNT_SID=AC_your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1your_twilio_number_here

# ===========================================
# REST Gateway
# ===========================================
# Endpoint for Alloy to scrape Prometheus metrics from Gateway (.NET on host).
GATEWAY_METRICS_ENDPOINT=host.docker.internal:5461

CorsOrigin=http://localhost:5173

GATEWAY_AUTH__AUTHSERVICEBASEURL=http://localhost:5100
GATEWAY_AUTH__ISSUER=d2-worx
GATEWAY_AUTH__AUDIENCE=d2-services

GATEWAY_SERVICEKEY__VALIDKEYS__0=your_service_key_here
GATEWAY_SERVICEKEY__VALIDKEYS__1=your_dkron_service_key_here

GATEWAY_AUTH_GRPC_API_KEY=your_gateway_api_key_here
GATEWAY_GEO_GRPC_API_KEY=your_gateway_api_key_here
GATEWAY_COMMS_GRPC_API_KEY=your_gateway_api_key_here

# ===========================================
# Dkron Manager
# ===========================================
DKRON_MGR__DKRON_URL=http://localhost:8888
DKRON_MGR__GATEWAY_URL=http://host.docker.internal:5461
DKRON_MGR__SERVICE_KEY=your_dkron_service_key_here
DKRON_MGR__RECONCILE_INTERVAL_MS=300000

# ===========================================
# SvelteKit / Web Client
# ===========================================
SVELTEKIT_PORT=5173
PUBLIC_API_URL=http://localhost:5000
VITE_ALLOWED_HOSTS=localhost

SVELTEKIT_GEO_CLIENT__APIKEY=your_sveltekit_geo_key_here
SVELTEKIT_AUTH__URL=http://localhost:5100
SVELTEKIT_GATEWAY__URL=http://localhost:5461
SVELTEKIT_GATEWAY__SERVICE_KEY=your_sveltekit_service_key_here
PUBLIC_GATEWAY_URL=http://localhost:5461
