# =============================================================================
# Dockerfile.auth — Node.js Auth Service (Hono + BetterAuth)
# Build context: repo root (../)
# Targets: dev (hot reload via tsx watch), prod (compiled JS)
# =============================================================================

# --- Base: Node.js with pnpm enabled via corepack ---
FROM node:24-slim AS base
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable && corepack prepare pnpm@10.30.3 --activate

# --- Dependencies: install full workspace with frozen lockfile ---
FROM base AS deps
WORKDIR /app

# Copy workspace root config files
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./

# Copy all Node.js packages (shared libs + services — workspace linking needs them all)
COPY backends/node/ backends/node/

# Copy contracts (i18n message JSON files needed at runtime)
COPY contracts/ contracts/

# SvelteKit package.json required for pnpm workspace resolution (it's a listed workspace member)
COPY clients/web/package.json clients/web/package.json

# Install all dependencies (devDeps needed for build stage)
RUN pnpm install --frozen-lockfile

# --- Build: compile TypeScript across the dependency graph ---
FROM deps AS build
WORKDIR /app

# Build auth-api and all its workspace dependencies (the ... suffix means "and deps")
RUN pnpm --filter @d2/auth-api... run build

# --- Dev stage: tsx watch for hot reload ---
FROM base AS dev
WORKDIR /app

ENV NODE_ENV=development

# HTTP (Hono) + gRPC
ARG AUTH_HTTP_PORT=5100
ARG AUTH_GRPC_PORT=5101
EXPOSE ${AUTH_HTTP_PORT} ${AUTH_GRPC_PORT}

# Source is bind-mounted at runtime. d2-node-init service pre-installs deps
# into the shared node_modules volume before this container starts.
ENTRYPOINT ["pnpm", "--filter", "@d2/auth-api", "run", "dev"]

# --- Prod stage: minimal runtime with pruned dependencies ---
FROM base AS prod
WORKDIR /app

ENV NODE_ENV=production

# HTTP (Hono) + gRPC
ARG AUTH_HTTP_PORT=5100
ARG AUTH_GRPC_PORT=5101
EXPOSE ${AUTH_HTTP_PORT} ${AUTH_GRPC_PORT}

# Copy the full built workspace (source + compiled dist/ + node_modules)
COPY --from=build /app/ .

# Remove devDependencies to shrink the image
RUN pnpm prune --prod

USER node

# Entry uses --import loader for OTel auto-instrumentation (service-defaults/register)
ENTRYPOINT ["node", "--import", "@d2/service-defaults/register", \
    "backends/node/services/auth/api/dist/main.js"]
