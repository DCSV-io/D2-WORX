    "db:push": "drizzle-kit push"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@aws-sdk/client-s3": "3.810.0",
    "@aws-sdk/s3-request-presigner": "3.810.0",
    "@d2/di": "workspace:*",
    "@d2/errors-pg": "workspace:*",
    "@d2/files-app": "workspace:*",
    "@d2/files-domain": "workspace:*",
    "@d2/handler": "workspace:*",
    "@d2/result-extensions": "workspace:*",
    "@d2/logging": "workspace:*",
    "@d2/messaging": "workspace:*",
    "@d2/protos": "workspace:*",
    "@d2/result": "workspace:*",
    "@d2/service-defaults": "workspace:*",
    "@grpc/grpc-js": "1.14.3",
    "drizzle-orm": "0.45.1",
    "pg": "8.19.0",
    "sharp": "0.34.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/pg": "8.16.0",
    "drizzle-kit": "0.31.9"
  }
